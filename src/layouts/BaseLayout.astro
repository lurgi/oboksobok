---
import { SiteHeader } from "../components/SiteHeader";
import "../styles/global.css";

type Props = {
  description: string;
  title: string;
};

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("image-load-state-enabled");
    </script>
  </head>
  <body>
    <SiteHeader />
    <slot />
    <script is:inline>
      (() => {
        const imageSelector = [
          "img[data-oboksobok-load-image]",
          ".oboksobok-notion .notion-asset-wrapper-image img:not(.lazy-image-preview)",
        ].join(",");

        const markDone = (image) => {
          image.dataset.oboksobokImageLoaded = "true";
        };

        const watchImage = (image) => {
          image.dataset.oboksobokLoadImage = "";

          if (image.complete) {
            markDone(image);
            return;
          }

          image.addEventListener("load", () => markDone(image), { once: true });
          image.addEventListener("error", () => markDone(image), { once: true });
        };

        document.querySelectorAll(imageSelector).forEach(watchImage);
      })();
    </script>
  </body>
</html>
