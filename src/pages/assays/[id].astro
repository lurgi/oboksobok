---
import { NotionPage } from "../../components/NotionPage";
import { PageLayout } from "../../components/PageLayout";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAssayDescription } from "../../lib/server/assayDescription";
import { type AssayPageWithRecordMap, notion } from "../../lib/server/notion";
import "react-notion-x/styles.css";
import "../../styles/notion-renderer.css";

export async function getStaticPaths() {
  const assays = await notion.getPublishedAssayPages();

  return assays.map((assay) => ({
    params: {
      id: assay.page.id,
    },
    props: {
      assay,
    },
  }));
}

type Props = {
  assay: AssayPageWithRecordMap;
};

const { assay } = Astro.props;
const title = assay.page.title;

const description = getAssayDescription(assay);
---

<BaseLayout
  title={title}
  description={description}
  pageType="article"
  authorName={assay.page.authorName}
  image={
    assay.page.thumbnail
      ? {
          alt: assay.page.thumbnail.alt ?? assay.page.title,
          src: assay.page.thumbnail.src,
        }
      : undefined
  }
>
  <PageLayout>
    <NotionPage
      authorName={assay.page.authorName}
      title={assay.page.title}
      recordMap={assay.recordMap}
      rootPageId={assay.page.notionPageId}
    />
  </PageLayout>
</BaseLayout>
