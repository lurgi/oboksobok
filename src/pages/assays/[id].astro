---
import { getBlockValue, getPageContentBlockIds, getTextContent } from "notion-utils";
import { NotionPage } from "../../components/NotionPage";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type AssayPageWithRecordMap, notion } from "../../lib/server/notion";
import "react-notion-x/styles.css";
import "../../styles/notion-renderer.css";

export async function getStaticPaths() {
  const assays = await notion.getPublishedAssayPages();

  return assays.map((assay) => ({
    params: {
      id: assay.page.id,
    },
    props: {
      assay,
    },
  }));
}

type Props = {
  assay: AssayPageWithRecordMap;
};

const { assay } = Astro.props;
const title = assay.page.title;

const descriptionBlockTypes = new Set([
  "text",
  "quote",
  "bulleted_list",
  "numbered_list",
  "callout",
  "toggle",
]);

const description = getAssayDescription(assay);

function getAssayDescription(assay: AssayPageWithRecordMap) {
  const contentBlockIds = getPageContentBlockIds(assay.recordMap, assay.page.notionPageId);
  const text = contentBlockIds
    .map((blockId) => getBlockValue(assay.recordMap.block[blockId]))
    .filter((block) => block && descriptionBlockTypes.has(block.type))
    .map((block) => getTextContent(block?.properties?.title))
    .filter(Boolean)
    .join(" ")
    .replace(/\s+/g, " ")
    .trim();

  return truncateDescription(text || assay.page.title);
}

function truncateDescription(value: string) {
  if (value.length <= 160) {
    return value;
  }

  return `${value.slice(0, 157).trimEnd()}...`;
}
---

<BaseLayout title={title} description={description}>
  <main class="essay-page">
    <div class="essay-layout">
      <NotionPage
        authorName={assay.page.authorName}
        title={assay.page.title}
        recordMap={assay.recordMap}
        rootPageId={assay.page.notionPageId}
      />
    </div>
  </main>
</BaseLayout>
