---
import { Divider } from "../components/Divider";
import { EssayThumbnailGrid } from "../components/EssayThumbnailGrid";
import { EssayThumbnailListCard } from "../components/EssayThumbnailListCard";
import { Hero } from "../components/Hero";
import { HomePageLayout } from "../components/HomePageLayout";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEssayDescription } from "../lib/server/essayDescription";
import { notion } from "../lib/server/notion";

const title = "오복소복";
const description =
  "오복소복은 쉴 때 우리가 하는 일을 담습니다. 사소하고 평범한 행위들 속에서 쉼의 가치를 발견하고 의미 있는 순간을 쌓아가는 공간입니다.";

const essays = await notion.getPublishedEssayPages();
const essayCards = essays.flatMap((essay) => {
  if (!essay.page.thumbnail) {
    return [];
  }

  return [
    {
      description: getEssayDescription(essay),
      href: `/essays/${essay.page.id}/`,
      id: essay.page.id,
      imageAlt: essay.page.thumbnail.alt ?? essay.page.title,
      imageAspectRatio: essay.page.thumbnail.aspectRatio,
      imageSrc: essay.page.thumbnail.src,
      title: essay.page.title,
    },
  ];
});

const thumbnailImageSizes =
  "(min-width: 1280px) 305px, (min-width: 1024px) calc((100vw - 60px) / 4), (min-width: 768px) calc((100vw - 32px) / 3), calc((100vw - 12px) / 2)";
---

<BaseLayout title={title} description={description} pageType="website">
  <HomePageLayout>
    <Hero />
    <Divider />
    <EssayThumbnailGrid>
      {
        essayCards.map((essay, index) => (
          <EssayThumbnailListCard
            title={essay.title}
            description={essay.description}
            href={essay.href}
            imageSrc={essay.imageSrc}
            imageAlt={essay.imageAlt}
            imageAspectRatio={essay.imageAspectRatio}
            imageLoading="eager"
            fetchPriority={index === 0 ? "high" : "auto"}
            imageSizes={thumbnailImageSizes}
          />
        ))
      }
    </EssayThumbnailGrid>
  </HomePageLayout>
</BaseLayout>
